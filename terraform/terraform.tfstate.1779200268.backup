            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "\"controller\":\n  \"hostPort\":\n    \"enabled\": true\n    \"ports\":\n      \"http\": 80\n      \"https\": 443\n  \"ingressClass\": \"nginx\"\n  \"ingressClassResource\":\n    \"name\": \"nginx\"\n  \"nodeSelector\":\n    \"ingress-ready\": \"true\"\n  \"publishService\":\n    \"enabled\": false\n  \"service\":\n    \"type\": \"NodePort\"\n  \"tolerations\":\n  - \"effect\": \"NoSchedule\"\n    \"key\": \"node-role.kubernetes.io/control-plane\"\n    \"operator\": \"Equal\"\n"
            ],
